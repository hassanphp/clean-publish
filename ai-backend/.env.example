# Metadata provider: "openai" | "vertex" | "google_ai"
# Use "openai" for GPT-4o mini vision (requires OPENAI_API_KEY)
# METADATA_PROVIDER=openai
# OPENAI_API_KEY=sk-xxx
# OPENAI_METADATA_MODEL=gpt-4o-mini

# Google Cloud (for Gemini when METADATA_PROVIDER=vertex or google_ai)
GOOGLE_CLOUD_PROJECT_ID=your-project-id
VERTEX_AI_LOCATION=us-central1
GEMINI_PROVIDER=vertex
GEMINI_MODEL=gemini-2.0-flash-001
GOOGLE_AI_API_KEY=  # When GEMINI_PROVIDER=google_ai

# Image edit provider: "replicate" (no quota) or "vertex" (GCP)
IMAGE_EDIT_PROVIDER=replicate

# Replicate - get token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_xxxx
# Optional: reve/edit-fast (default, faster) or reve/edit (higher quality for complex edits)
# REPLICATE_EDIT_MODEL=reve/edit
# V3 hybrid uses remove-bg for detail shots (lucataco/remove-bg:95fcc2a...)
# REMOVE_BG_MODEL=lucataco/remove-bg:95fcc2a26d3899cd6c2691c900465aaeff466285a65c14638cc5f36f34befaf1

# Vertex Imagen (only when IMAGE_EDIT_PROVIDER=vertex)
VERTEX_IMAGEN_MODEL=imagen-3.0-capability-001

# V6: Fal.ai FLUX multi-image reference (studio adoption) - get key at https://fal.ai/dashboard/keys
FAL_KEY=your-fal-api-key
# Optional: fal-ai/flux-2-flex/edit (default) or fal-ai/flux-2/edit
# FAL_FLUX_EDIT_MODEL=fal-ai/flux-2-flex/edit

# V7: Replicate Flux 2 Pro multi-image reference (studio adoption)
# REPLICATE_STUDIO_MODEL=black-forest-labs/flux-2-pro

# V11: OpenAI-only (metadata + GPT Image 1.5 for image editing). Requires OPENAI_API_KEY.
# OPENAI_GPT_IMAGE_MODEL=gpt-image-1.5

DATABASE_URL=sqlite:///./app.db

# Webhook mode (V6/V7): public URL so Fal/Replicate can reach webhooks. Use ngrok for local dev.
# SERVER_BASE_URL=https://your-app.ngrok.io

# Redis for job update Pub/Sub (optional; V6/V7 webhook flow uses it)
# REDIS_URL=redis://localhost:6379
