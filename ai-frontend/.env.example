# Backend API base URL (no trailing slash).
# Production: https://api.carveo.eu
# Local dev with remote backend: https://api.carveo.eu
# Local dev with local backend: http://localhost:8000
NEXT_PUBLIC_API_URL=https://api.carveo.eu

# Cookie domain for auth - required when using both www and apex (e.g. www.carveo.eu + carveo.eu).
# Set to .carveo.eu so the cookie works on both. Omit for localhost.
# COOKIE_DOMAIN=.carveo.eu
